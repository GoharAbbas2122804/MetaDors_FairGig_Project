<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>FairGig Income Certificate</title>
    <style>
      body {
        font-family: Arial, sans-serif;
        color: #111827;
        margin: 24px;
      }
      .header {
        display: flex;
        justify-content: space-between;
        border-bottom: 2px solid #e5e7eb;
        padding-bottom: 12px;
        margin-bottom: 20px;
      }
      .title {
        font-size: 24px;
        margin: 0;
      }
      .subtle {
        color: #6b7280;
        font-size: 12px;
        margin: 4px 0 0;
      }
      table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 16px;
      }
      th,
      td {
        border: 1px solid #d1d5db;
        padding: 8px 10px;
        text-align: left;
      }
      th {
        background: #f9fafb;
      }
      .totals {
        margin-top: 18px;
      }
      .totals p {
        margin: 4px 0;
      }
      .footer {
        margin-top: 26px;
        font-size: 12px;
        color: #4b5563;
      }
    </style>
  </head>
  <body>
    <div class="header">
      <div>
        <h1 class="title">FairGig Verified Income Summary</h1>
        <p class="subtle">Certificate ID: <%= certificateId %></p>
      </div>
      <div>
        <p class="subtle">Issued: <%= issuedDate %></p>
        <p class="subtle">Worker ID: <%= workerId %></p>
      </div>
    </div>

    <p><strong>Coverage:</strong> <%= startDate %> to <%= endDate %></p>
    <p><strong>Total Verified Shifts:</strong> <%= totals.totalShifts %></p>

    <table>
      <thead>
        <tr>
          <th>Platform</th>
          <th>Total Shifts</th>
          <th>Gross</th>
          <th>Deductions</th>
          <th>Net</th>
        </tr>
      </thead>
      <tbody>
        <% perPlatform.forEach((row) => { %>
        <tr>
          <td><%= row.platform %></td>
          <td><%= row.totalShifts %></td>
          <td>$<%= row.gross.toFixed(2) %></td>
          <td>$<%= row.deductions.toFixed(2) %></td>
          <td>$<%= row.net.toFixed(2) %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>

    <div class="totals">
      <p><strong>Total Gross:</strong> $<%= totals.gross.toFixed(2) %></p>
      <p><strong>Total Deductions:</strong> $<%= totals.deductions.toFixed(2) %></p>
      <p><strong>Total Net:</strong> $<%= totals.net.toFixed(2) %></p>
    </div>

    <p class="footer">
      This summary is generated from confirmed shift records in FairGig and is intended
      for formal verification use by housing and financial institutions.
    </p>
  </body>
</html>
